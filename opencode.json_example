{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "lsp": true,
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "Library/**",
      "Temp/**",
      "Obj/**",
      "Build/**",
      "Builds/**",
      "Logs/**",
      "UserSettings/**",
      "MemoryCaptures/**",
      "bin/**",
      "obj/**"
    ]
  }
}
