    "baselineContractEntryV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ignored_violations"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Contract ID matching the id field in an architecture contract."
        },
        "ignored_violations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/baselineViolationV1"
          },
          "minItems": 1,
          "description": "Violation entries to suppress for this contract."
        }
      }
    },
    "baselineContractEntryV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ignored_violations"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Contract ID matching the id field in an architecture contract."
        },
        "ignored_violations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/baselineViolationV2"
          },
          "minItems": 1,
          "description": "Violation entries to suppress for this contract."
        }
      }
    },
    "baselineViolationV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "forbidden_reference"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "minLength": 1,
          "description": "Exact source type name to suppress (identity-bearing in version 1)."
        },
        "forbidden_reference": {
          "type": "string",
          "minLength": 1,
          "description": "Exact forbidden reference name to suppress (identity-bearing in version 1)."
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable migration reason or issue reference. Never participates in matching."
        }
      }
    },
    "baselineViolationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "forbidden_reference",
        "identity_version",
        "contract_family",
        "kind",
        "occurrence"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable source type name. Display-only in version 2 documents (identity is the structured fields below)."
        },
        "forbidden_reference": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable forbidden reference name. Display-only in version 2 documents (identity is the structured fields below)."
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable migration reason or issue reference. Never participates in matching."
        },
        "identity_version": {
          "type": "integer",
          "enum": [
            2
          ],
          "description": "Structured identity schema version for this entry. Required in version 2 documents so a legacy-shaped entry mislabeled as version 2 cannot pass validation."
        },
        "contract_family": {
          "type": "string",
          "minLength": 1,
          "description": "Contract family this identity belongs to (e.g. method_body, cycles), derived from the contract group name."
        },
        "kind": {
          "type": "string",
          "enum": [
            "dependency",
            "reference",
            "call",
            "package",
            "framework",
            "api_change",
            "coverage"
          ],
          "description": "Denormalized, stable classification of the violation kind."
        },
        "source_assembly": {
          "type": "string",
          "minLength": 1,
          "description": "Assembly containing the source type, where the checking family supplies it. Absent for families not yet assembly-qualified."
        },
        "source_member": {
          "type": "string",
          "minLength": 1,
          "description": "Source member, where applicable."
        },
        "target_assembly": {
          "type": "string",
          "minLength": 1,
          "description": "Assembly containing the target/forbidden symbol, where the checking family supplies it."
        },
        "target_type": {
          "type": "string",
          "minLength": 1,
          "description": "Target type, where distinct from the forbidden reference display text."
        },
        "target_member": {
          "type": "string",
          "minLength": 1,
          "description": "Exact forbidden symbol/member/overload. Falls back to the forbidden_reference display text for families that don't yet resolve a member independently."
        },
        "occurrence": {
          "type": "integer",
          "minimum": 0,
          "description": "Stable, non-line-based ordinal discriminator among matches that otherwise share every other identity field within the same source unit. Required (0 for the first occurrence) so identity is always fully structured."
        },
        "configuration": {
          "type": "string",
          "minLength": 1,
          "description": "Configuration/TFM qualifier, only populated where semantically relevant to the family."
        }
      }
    }
  }
}
