{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archlinternet.dev/schema/baseline.schema.json",
  "title": "ArchLinterNet baseline file",
  "description": "Schema for baseline YAML files that suppress known violations for architecture policy migration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "baseline"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [
        1,
        2
      ],
      "description": "Baseline file format version. Version 1 uses the legacy exact (source_type, forbidden_reference) pair as identity, and its ignored_violations entries MUST NOT carry structured identity fields. Version 2 uses a versioned, structured ArchitectureViolationIdentity per entry, and every entry MUST carry identity_version, contract_family, kind, and occurrence (produced by 'baseline generate' and 'baseline migrate') so a malformed or hand-edited entry cannot silently pass as valid."
    },
    "baseline": {
      "type": "object",
      "description": "Contract group entries indexed by contract group name. The exact shape required for each entry depends on the top-level 'version' (see the version-conditional definitions below)."
    }
  },
  "if": {
    "properties": {
      "version": {
        "const": 2
      }
    }
  },
  "then": {
    "properties": {
      "baseline": {
        "$ref": "#/$defs/baselineGroupsV2"
      }
    }
  },
  "else": {
    "properties": {
      "baseline": {
        "$ref": "#/$defs/baselineGroupsV1"
      }
    }
  },
