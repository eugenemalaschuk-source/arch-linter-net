{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archlinternet.dev/schema/baseline.schema.json",
  "title": "ArchLinterNet baseline file",
  "description": "Schema for baseline YAML files that suppress known violations for architecture policy migration.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "baseline"],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1, 2],
      "description": "Baseline file format version. Version 1 uses the legacy exact (source_type, forbidden_reference) pair as identity. Version 2 uses a versioned, structured ArchitectureViolationIdentity per entry (see baselineViolation) and is produced by 'baseline generate' and 'baseline migrate'."
    },
    "baseline": {
      "type": "object",
      "description": "Contract group entries indexed by contract group name.",
      "properties": {
        "strict": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_cycles": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_cycles": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_method_body": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_method_body": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_assembly_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_assembly_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_assembly_dependency": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_assembly_dependency": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_assembly_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_assembly_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_package_dependency": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_package_dependency": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_package_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_package_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_project_metadata": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_project_metadata": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_protected": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_protected": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_external": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_external": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_external_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_external_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_acyclic_siblings": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_acyclic_siblings": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_type_placement": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_type_placement": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_layout_conventions": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_layout_conventions": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_public_api_surface": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_public_api_surface": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_attribute_usage": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_attribute_usage": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_inheritance": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_inheritance": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_interface_implementation": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_interface_implementation": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_composition": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_composition": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "strict_coverage": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        },
        "audit_coverage": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineContractEntry" },
          "default": []
        }
            },
      "additionalProperties": false
    }
  },
  "$defs": {
    "baselineContractEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ignored_violations"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Contract ID matching the id field in an architecture contract."
        },
        "ignored_violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/baselineViolation" },
          "minItems": 1,
          "description": "Violation entries to suppress for this contract."
        }
      }
    },
    "baselineViolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "forbidden_reference"],
      "properties": {
        "source_type": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable source type name. Identity-bearing in version 1 documents; display-only in version 2 documents (identity is the structured fields below)."
        },
        "forbidden_reference": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable forbidden reference name. Identity-bearing in version 1 documents; display-only in version 2 documents (identity is the structured fields below)."
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable migration reason or issue reference. Never participates in matching."
        },
        "identity_version": {
          "type": "integer",
          "enum": [2],
          "description": "Structured identity schema version for this entry. Only present in version 2 documents."
        },
        "contract_family": {
          "type": "string",
          "minLength": 1,
          "description": "Contract family this identity belongs to (e.g. method_body, cycles), derived from the contract group name."
        },
        "kind": {
          "type": "string",
          "enum": ["dependency", "reference", "call", "package", "framework", "api_change", "coverage"],
          "description": "Denormalized, stable classification of the violation kind."
        },
        "source_assembly": {
          "type": "string",
          "minLength": 1,
          "description": "Assembly containing the source type, where the checking family supplies it. Null/absent for families not yet assembly-qualified."
        },
        "source_member": {
          "type": "string",
          "minLength": 1,
          "description": "Source member, where applicable."
        },
        "target_assembly": {
          "type": "string",
          "minLength": 1,
          "description": "Assembly containing the target/forbidden symbol, where the checking family supplies it."
        },
        "target_type": {
          "type": "string",
          "minLength": 1,
          "description": "Target type, where distinct from the forbidden reference display text."
        },
        "target_member": {
          "type": "string",
          "minLength": 1,
          "description": "Exact forbidden symbol/member/overload. Falls back to the forbidden_reference display text for families that don't yet resolve a member independently."
        },
        "occurrence": {
          "type": "integer",
          "minimum": 0,
          "description": "Stable, non-line-based ordinal discriminator among matches that otherwise share every other identity field within the same source unit."
        },
        "configuration": {
          "type": "string",
          "minLength": 1,
          "description": "Configuration/TFM qualifier, only populated where semantically relevant to the family."
        }
      }
    }
  }
}
