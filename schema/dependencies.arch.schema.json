{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archlinternet.dev/schema/dependencies.arch.schema.json",
  "title": "ArchLinterNet dependency architecture policy",
  "description": "Schema for architecture/dependencies.arch.yml policy files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "layers", "analysis", "contracts"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Policy schema version. Current supported version is 1."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable policy name."
    },
    "layers": {
      "type": "object",
      "description": "Named layer definitions referenced by contracts.",
      "additionalProperties": { "$ref": "#/$defs/layer" }
    },
    "external_dependencies": {
      "type": "object",
      "description": "Named vendor/framework dependency groups referenced by external dependency contracts.",
      "additionalProperties": { "$ref": "#/$defs/externalDependencyGroup" },
      "default": {}
    },
    "legacy_runtime_layers": {
      "type": "array",
      "description": "Namespace prefixes used by dependency contracts with forbidden_legacy_runtime enabled.",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "analysis": { "$ref": "#/$defs/analysis" },
    "contracts": { "$ref": "#/$defs/contracts" }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "nonBlankStringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
      "default": []
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace"],
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1,
          "description": "Namespace prefix or constrained glob pattern. Supports '*' as a single-segment wildcard (e.g. 'App.Features.*'). Literal prefixes use exact or child-namespace semantics. See documentation for full glob syntax."
        },
        "namespace_suffix": {
          "type": "string",
          "description": "Optional namespace suffix constraint, matched after the namespace prefix."
        },
        "external": {
          "type": "boolean",
          "default": false,
          "description": "When true, suppresses the empty-layer configuration diagnostic for this layer. Use for namespaces whose assemblies may not be available in the scan environment (external SDKs, engine types, platform-conditional namespaces)."
        }
      }
    },
    "externalDependencyGroup": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": ["namespace_prefixes"],
          "properties": {
            "namespace_prefixes": {
              "minItems": 1
            }
          }
        },
        {
          "required": ["type_prefixes"],
          "properties": {
            "type_prefixes": {
              "minItems": 1
            }
          }
        }
      ],
      "properties": {
        "namespace_prefixes": {
          "$ref": "#/$defs/nonBlankStringList",
          "description": "Namespace prefixes matched with exact or child-namespace semantics against referenced external types."
        },
        "type_prefixes": {
          "$ref": "#/$defs/nonBlankStringList",
          "description": "Full type-name prefixes matched against referenced external types."
        }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_assemblies"],
      "properties": {
        "target_assemblies": {
          "type": "array",
          "description": "Assembly names to load and scan.",
          "items": { "type": "string", "minLength": 1 }
        },
        "assembly_search_paths": {
          "$ref": "#/$defs/stringList",
          "description": "Additional directories used when resolving target assemblies."
        },
        "source_roots": {
          "$ref": "#/$defs/stringList",
          "description": "Source roots used by method-body Roslyn scanning."
        },
        "unmatched_ignored_violations": {
          "type": "string",
          "enum": ["error", "warn", "off"],
          "default": "error",
          "description": "Behavior when an ignored_violations entry matches no current violation. 'error' (default) fails validation, 'warn' reports but does not fail, 'off' skips detection."
        },
        "policy_consistency": {
          "type": "string",
          "enum": ["error", "warn", "off"],
          "default": "error",
          "description": "Behavior when the policy-consistency check finds internal contradictions in the policy itself (duplicate IDs, allow/forbid conflicts, independence conflicts, protected-importer conflicts, layer overlaps, unreachable contracts). 'error' (default) fails validation, 'warn' reports but does not fail, 'off' suppresses findings. The check itself always runs."
        },
        "coverage": {
          "type": "string",
          "enum": ["error", "warn", "off"],
          "default": "error",
          "description": "Behavior when a declared coverage contract finds uncovered, unknown, stale, or empty-input first-party units. 'error' (default) fails validation, 'warn' reports but does not fail, 'off' suppresses findings even for an explicitly declared coverage contract. Backward compatibility does not depend on this default: a policy with no strict_coverage/audit_coverage contracts is unaffected regardless of this setting, because no coverage contract exists to produce a finding."
        },
        "condition_sets": {
          "type": "object",
          "description": "Named preprocessor symbol sets for conditional compilation analysis. Each key is a condition set name (e.g. 'runtime', 'editor'), each value is an array of preprocessor symbols (e.g. ['UNITY_EDITOR']). Only affects Roslyn source/method-body scanning.",
          "default": {},
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "default_condition_set": {
          "type": "string",
          "description": "Name of the default condition set used when --condition-set is not provided on the CLI. Must match a key in condition_sets. When empty or unset, no preprocessor symbols are defined.",
          "default": ""
        }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strict": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyContract" },
          "default": []
        },
        "audit": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyContract" },
          "default": []
        },
        "strict_layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/layerContract" },
          "default": []
        },
        "audit_layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/layerContract" },
          "default": []
        },
        "strict_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/allowOnlyContract" },
          "default": []
        },
        "audit_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/allowOnlyContract" },
          "default": []
        },
        "strict_cycles": {
          "type": "array",
          "items": { "$ref": "#/$defs/cycleContract" },
          "default": []
        },
        "audit_cycles": {
          "type": "array",
          "items": { "$ref": "#/$defs/cycleContract" },
          "default": []
        },
        "strict_method_body": {
          "type": "array",
          "items": { "$ref": "#/$defs/methodBodyContract" },
          "default": []
        },
        "audit_method_body": {
          "type": "array",
          "items": { "$ref": "#/$defs/methodBodyContract" },
          "default": []
        },
        "strict_asmdef": {
          "type": "array",
          "items": { "$ref": "#/$defs/asmdefContract" },
          "default": []
        },
        "audit_asmdef": {
          "type": "array",
          "items": { "$ref": "#/$defs/asmdefContract" },
          "default": []
        },
        "strict_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/independenceContract" },
          "default": []
        },
        "audit_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/independenceContract" },
          "default": []
        },
        "strict_assembly_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyIndependenceContract" },
          "default": []
        },
        "audit_assembly_independence": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyIndependenceContract" },
          "default": []
        },
        "strict_assembly_dependency": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyDependencyContract" },
          "default": []
        },
        "audit_assembly_dependency": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyDependencyContract" },
          "default": []
        },
        "strict_assembly_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyAllowOnlyContract" },
          "default": []
        },
        "audit_assembly_allow_only": {
          "type": "array",
          "items": { "$ref": "#/$defs/assemblyAllowOnlyContract" },
          "default": []
        },
        "strict_protected": {
          "type": "array",
          "items": { "$ref": "#/$defs/protectedContract" },
          "default": []
        },
        "audit_protected": {
          "type": "array",
          "items": { "$ref": "#/$defs/protectedContract" },
          "default": []
        },
        "strict_external": {
          "type": "array",
          "items": { "$ref": "#/$defs/externalDependencyContract" },
          "default": []
        },
        "audit_external": {
          "type": "array",
          "items": { "$ref": "#/$defs/externalDependencyContract" },
          "default": []
        },
        "strict_layer_templates": {
          "type": "array",
          "items": { "$ref": "#/$defs/layerTemplateContract" },
          "default": []
        },
        "audit_layer_templates": {
          "type": "array",
          "items": { "$ref": "#/$defs/layerTemplateContract" },
          "default": []
        },
        "strict_acyclic_siblings": {
          "type": "array",
          "items": { "$ref": "#/$defs/acyclicSiblingContract" },
          "default": []
        },
        "audit_acyclic_siblings": {
          "type": "array",
          "items": { "$ref": "#/$defs/acyclicSiblingContract" },
          "default": []
        },
        "strict_coverage": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverageContract" },
          "default": []
        },
        "audit_coverage": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverageContract" },
          "default": []
        }
      }
    },
    "baseContractFields": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1, "description": "Stable contract identifier for CLI selection and cross-referencing." },
        "reason": { "type": "string" }
      }
    },
    "ignoredViolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "forbidden_reference", "reason"],
      "properties": {
        "source_type": {
          "type": "string",
          "minLength": 1,
          "description": "Source type name or narrow glob pattern to suppress."
        },
        "forbidden_reference": {
          "type": "string",
          "minLength": 1,
          "description": "Forbidden reference name or narrow glob pattern to suppress."
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable migration reason or issue reference."
        }
      }
    },
    "ignoredViolations": {
      "type": "array",
      "items": { "$ref": "#/$defs/ignoredViolation" },
      "default": []
    },
    "dependencyContract": {
      "allOf": [
        { "$ref": "#/$defs/baseContractFields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "source", "forbidden"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "forbidden": { "$ref": "#/$defs/stringList" },
            "allowed_types": { "$ref": "#/$defs/stringList" },
            "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
            "forbidden_legacy_runtime": { "type": "boolean", "default": false },
            "dependency_depth": {
              "type": "string",
              "enum": ["direct", "transitive"],
              "default": "direct",
              "description": "Evaluation depth for dependency checking. 'direct' checks only immediate references (1 level). 'transitive' follows the dependency graph via BFS and reports violations at any depth."
            },
            "reason": { "type": "string" }
          }
        }
      ]
    },
    "layerContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "layers"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "layers": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "allowOnlyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "allowed"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "allowed": { "$ref": "#/$defs/stringList" },
        "allowed_types": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "cycleContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "layers"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "layers": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "acyclicSiblingContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ancestors"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1, "description": "Stable contract identifier for CLI selection and cross-referencing." },
        "ancestors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "methodBodyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "forbidden_calls"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "forbidden_calls": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "asmdefContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source_assemblies"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "source_assemblies": { "$ref": "#/$defs/stringList" },
        "forbidden_editor_refs": { "type": "boolean", "default": false },
        "forbidden_asmdef_prefixes": { "$ref": "#/$defs/stringList" },
        "reason": { "type": "string" }
      }
    },
    "independenceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "layers"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "layers": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "assemblyIndependenceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "assemblies"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "assemblies": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "assemblyDependencyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "forbidden"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "forbidden": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "assemblyAllowOnlyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "allowed"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "allowed": { "$ref": "#/$defs/stringList" },
        "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
        "reason": { "type": "string" }
      }
    },
    "protectedContract": {
      "allOf": [
        { "$ref": "#/$defs/baseContractFields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "protected", "allowed_importers"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "id": { "type": "string", "minLength": 1 },
            "protected": { "$ref": "#/$defs/stringList" },
            "allowed_importers": { "$ref": "#/$defs/stringList" },
            "allowed_types": { "$ref": "#/$defs/stringList" },
            "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
            "reason": { "type": "string" }
          }
        }
      ]
    },
    "externalDependencyContract": {
      "allOf": [
        { "$ref": "#/$defs/baseContractFields" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "source", "forbidden"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "id": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "forbidden": { "$ref": "#/$defs/stringList" },
            "ignored_violations": { "$ref": "#/$defs/ignoredViolations" },
            "reason": { "type": "string" }
          }
        }
      ]
    },
    "layerTemplateContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "containers", "layers"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "containers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/templateLayer" },
          "minItems": 1
        },
        "reason": { "type": "string" },
        "exhaustive": {
          "type": "boolean",
          "default": false,
          "description": "When true, the linter checks for sibling namespaces under each container that are not mapped into any declared layer. Unmapped siblings with types produce violations."
        }
      }
    },
    "templateLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "coverageNamespaceRoot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1, "description": "Namespace prefix or glob pattern, same syntax as layers.<name>.namespace." },
        "namespace_suffix": { "type": "string", "description": "Optional namespace suffix constraint, same syntax as layers.<name>.namespace_suffix." }
      }
    },
    "coverageDiscoveryRoot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["include"],
      "properties": {
        "include": { "$ref": "#/$defs/stringList", "description": "Glob patterns for project/assembly discovery roots." },
        "exclude": { "$ref": "#/$defs/stringList", "description": "Glob patterns excluded from include, before coverage exclusion reasons apply." }
      }
    },
    "coverageNamespaceExclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "anyOf": [
        { "required": ["namespace"] },
        { "required": ["namespace_suffix"] }
      ],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "namespace_suffix": { "type": "string", "minLength": 1 },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Required justification for excluding this unit from coverage."
        }
      }
    },
    "coverageProjectExclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "reason"],
      "properties": {
        "project": { "type": "string", "minLength": 1 },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Required justification for excluding this unit from coverage."
        }
      }
    },
    "coverageAssemblyExclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assembly", "reason"],
      "properties": {
        "assembly": { "type": "string", "minLength": 1 },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Required justification for excluding this unit from coverage."
        }
      }
    },
    "coverageContractIdExclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_id", "reason"],
      "properties": {
        "contract_id": { "type": "string", "minLength": 1 },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Required justification for excluding this referenced contract from rule-input coverage."
        }
      }
    },
    "coverageContract": {
      "allOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "scope", "reason"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "id": { "type": "string", "minLength": 1, "description": "Stable contract identifier for CLI selection and cross-referencing." },
            "scope": {
              "type": "string",
              "enum": ["namespace", "project", "assembly", "dependency_edge", "rule_input"],
              "description": "Which kind of first-party unit this coverage contract classifies."
            },
            "roots": {
              "type": "array",
              "minItems": 1,
              "description": "Units to classify (the scan boundary the contract classifies, not coverage evidence by itself). Required for, and only valid with, scope: namespace, project, or assembly. Item shape depends on scope: namespace uses coverageNamespaceRoot, project/assembly use coverageDiscoveryRoot (see scope-specific allOf constraints below)."
            },
            "between": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 2,
                "maxItems": 2
              },
              "minItems": 1,
              "description": "Declared-layer-name pairs to classify. Required for, and only valid with, scope: dependency_edge."
            },
            "contract_ids": {
              "$ref": "#/$defs/stringList",
              "description": "Contract IDs whose rule inputs are checked for stale/empty-input status. Required for, and only valid with, scope: rule_input."
            },
            "exclude": {
              "type": "array",
              "description": "Excluded units, each carrying a required reason. Item shape depends on scope: namespace uses coverageNamespaceExclusion, project uses coverageProjectExclusion, assembly uses coverageAssemblyExclusion, rule_input uses coverageContractIdExclusion. Not valid for scope: dependency_edge (no exclusion shape defined for that scope yet)."
            },
            "reason": {
              "type": "string",
              "minLength": 1,
              "description": "Why this coverage contract exists."
            },
            "ignored_violations": { "$ref": "#/$defs/ignoredViolations" }
          }
        },
        {
          "if": { "properties": { "scope": { "const": "namespace" } }, "required": ["scope"] },
          "then": {
            "required": ["roots"],
            "properties": {
              "roots": { "items": { "$ref": "#/$defs/coverageNamespaceRoot" } },
              "exclude": { "items": { "$ref": "#/$defs/coverageNamespaceExclusion" }, "default": [] }
            },
            "not": { "anyOf": [{ "required": ["between"] }, { "required": ["contract_ids"] }] }
          }
        },
        {
          "if": { "properties": { "scope": { "const": "project" } }, "required": ["scope"] },
          "then": {
            "required": ["roots"],
            "properties": {
              "roots": { "items": { "$ref": "#/$defs/coverageDiscoveryRoot" } },
              "exclude": { "items": { "$ref": "#/$defs/coverageProjectExclusion" }, "default": [] }
            },
            "not": { "anyOf": [{ "required": ["between"] }, { "required": ["contract_ids"] }] }
          }
        },
        {
          "if": { "properties": { "scope": { "const": "assembly" } }, "required": ["scope"] },
          "then": {
            "required": ["roots"],
            "properties": {
              "roots": { "items": { "$ref": "#/$defs/coverageDiscoveryRoot" } },
              "exclude": { "items": { "$ref": "#/$defs/coverageAssemblyExclusion" }, "default": [] }
            },
            "not": { "anyOf": [{ "required": ["between"] }, { "required": ["contract_ids"] }] }
          }
        },
        {
          "if": { "properties": { "scope": { "const": "dependency_edge" } }, "required": ["scope"] },
          "then": {
            "required": ["between"],
            "not": { "anyOf": [{ "required": ["roots"] }, { "required": ["contract_ids"] }, { "required": ["exclude"] }] }
          }
        },
        {
          "if": { "properties": { "scope": { "const": "rule_input" } }, "required": ["scope"] },
          "then": {
            "required": ["contract_ids"],
            "properties": {
              "exclude": { "items": { "$ref": "#/$defs/coverageContractIdExclusion" }, "default": [] }
            },
            "not": { "anyOf": [{ "required": ["roots"] }, { "required": ["between"] }] }
          }
        }
      ]
    }
  }
}
