<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>ArchLinterNet.Core</PackageId>
    <Description>YAML-first architecture contract engine for .NET projects. Loads declarative architecture policies, resolves assemblies, and validates dependency rules.</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ArchLinterNet.Core.Tests" />
    <InternalsVisibleTo Include="ArchLinterNet.Unity" />
    <InternalsVisibleTo Include="ArchLinterNet.Cli" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0" />
  </ItemGroup>

</Project>
